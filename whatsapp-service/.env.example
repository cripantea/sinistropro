# Porta su cui il servizio ascolta (solo su 127.0.0.1, mai esposto pubblicamente)
PORT=3002

# Secret condiviso con Laravel: deve essere identico a WHATSAPP_SERVICE_SECRET nel .env di Laravel.
# Generane uno con: openssl rand -hex 32
WHATSAPP_SERVICE_SECRET=

# URL pubblico del webhook Laravel che riceve messaggi/eventi in ingresso
LARAVEL_WEBHOOK_URL=https://login.sinistropro.it/api/whatsapp/webhook

# Cartella dove open-wa salva i dati di sessione (persistente tra i deploy)
WHATSAPP_SESSIONS_DIR=/var/www/html/sinistri-tenant/persistent/whatsapp-sessions
